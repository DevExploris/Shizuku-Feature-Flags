{
    "name": "devexploris/shizuku-feature-flags",
    "description": "Symfony bundle to manage feature flags backed by Doctrine ORM",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": [
        "symfony",
        "bundle",
        "feature-flags",
        "feature-toggle",
        "flags",
        "toggle",
        "doctrine",
        "orm",
        "twig",
        "profiler"
    ],
    "authors": [
        {
            "name": "devexploris",
            "email": "contact@devexploris.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "doctrine/doctrine-bundle": "^2.0|^3.0",
        "doctrine/orm": "^3.0",
        "symfony/cache-contracts": "^3.0",
        "symfony/console": "^7.4|^8.0",
        "symfony/dependency-injection": "^7.4|^8.0",
        "symfony/http-kernel": "^7.4|^8.0",
        "twig/twig": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "symfony/framework-bundle": "^7.4|^8.0",
        "symfony/web-profiler-bundle": "^7.4|^8.0"
    },
    "suggest": {
        "symfony/cache": "Provides the cache.app pool used for flag caching (symfony/cache-contracts is the interface; this is the implementation)",
        "symfony/web-profiler-bundle": "Displays a Feature Flags panel in the Symfony Profiler toolbar"
    },
    "autoload": {
        "psr-4": {
            "Devexploris\\ShizukuFeatureFlags\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Devexploris\\ShizukuFeatureFlags\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0-dev"
        }
    }
}
